# Required for production newsletter generation.
OPENAI_API_KEY=

# Model selection. Configure these in the environment rather than hard-coding.
OPENAI_MODEL_HIGH_QUALITY=
OPENAI_MODEL_FAST=

# Newsletter controls.
MAX_CANDIDATES=0
MAX_SHORTLIST=40
MAX_REVIEW_STORIES=0
MAX_FINAL_STORIES=0
MIN_FINAL_STORIES=8
MAX_SOURCES_PER_STORY=3
MAX_EXTRACT_CHARS_PER_ARTICLE=6000
REQUIRE_HUMAN_REVIEW=true
DRY_RUN_NO_AI=false
ENABLE_OPENAI_WEB_SEARCH=false
NEWSLETTER_NAME="The Legal Edge Ireland"
NEWSLETTER_SENDER_NAME=
NEWSLETTER_SENDER_EMAIL=
# Optional. Leave blank to use the bundled GitHub-hosted PNG logo in generated email HTML.
NEWSLETTER_LOGO_URL=

# Future beehiiv integration placeholders only. Not required for the MVP.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Optional Brevo draft-campaign integration. Creates drafts only; never sends.
BREVO_API_KEY=
BREVO_SENDER_NAME="The Legal Edge Ireland"
BREVO_SENDER_EMAIL=
# Use BREVO_SENDER_ID instead of BREVO_SENDER_EMAIL only if you prefer a Brevo sender ID.
BREVO_SENDER_ID=
# Prefer names so Brevo list IDs can change without breaking draft creation.
BREVO_LIST_NAMES=test-list,the-legal-edge-IE
# Optional fallback: comma-separated Brevo contact list IDs, e.g. 12 or 12,34.
# Ignored when BREVO_LIST_NAMES is set.
BREVO_LIST_IDS=
BREVO_REPLY_TO=
# Optional. Some Brevo plans/accounts reject campaign tags, so leave blank unless you use them.
BREVO_CAMPAIGN_TAG=

# Optional GitHub PR settings for local use. GitHub Actions uses built-in env vars.
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_BASE_BRANCH=main

# Optional hosted review dashboard. Not required for the core MVP.
# Use a fine-grained GitHub token with repository contents read/write and Actions workflow dispatch permissions.
DASHBOARD_GITHUB_TOKEN=
DASHBOARD_GITHUB_REPOSITORY=glen-byrne/legal-innovation-newsletter
DASHBOARD_BASE_BRANCH=main
DASHBOARD_WORKFLOW_FILE=generate-newsletter.yml
DASHBOARD_PASSWORD=
DASHBOARD_SECRET_KEY=
DASHBOARD_COOKIE_SECURE=true
DASHBOARD_ALLOW_NO_AUTH=false
# Uses OpenAI to draft the generated HTML issue overview when OpenAI settings are present.
DASHBOARD_AI_INTRO=true
