<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ issue.newsletter_name }}</title>
    <style>
      body { margin: 0; padding: 0; background: #ffffff; color: #14213d; font-family: Arial, Helvetica, sans-serif; }
      table { border-collapse: collapse; }
      a { color: #0f6b77; text-decoration: underline; }
      .wrapper { width: 100%; background: #ffffff; }
      .container { width: 100%; max-width: 680px; margin: 0 auto; }
      .header { padding: 28px 24px 18px 24px; border-bottom: 3px solid #0f6b77; }
      .title { margin: 0; font-size: 28px; line-height: 1.2; color: #102a43; font-weight: 700; }
      .date { margin: 8px 0 0 0; font-size: 13px; color: #52616b; }
      .intro { padding: 22px 24px; font-size: 16px; line-height: 1.55; color: #243b53; }
      .story { padding: 22px 24px; border-top: 1px solid #d9e2ec; }
      .story h2 { margin: 0 0 8px 0; font-size: 20px; line-height: 1.3; color: #102a43; }
      .meta { margin: 0 0 12px 0; font-size: 13px; color: #52616b; }
      .summary { margin: 0 0 12px 0; font-size: 15px; line-height: 1.55; color: #243b53; }
      .why { margin: 0 0 12px 0; font-size: 15px; line-height: 1.55; color: #243b53; }
      .why strong { color: #0b4f5c; }
      .sources { margin: 0; font-size: 13px; line-height: 1.5; color: #52616b; }
      .footer { padding: 22px 24px 30px 24px; border-top: 1px solid #d9e2ec; font-size: 12px; line-height: 1.5; color: #52616b; }
      @media screen and (max-width: 520px) {
        .header, .intro, .story, .footer { padding-left: 18px !important; padding-right: 18px !important; }
        .title { font-size: 24px !important; }
        .story h2 { font-size: 18px !important; }
      }
    </style>
  </head>
  <body>
    <table role="presentation" class="wrapper" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table role="presentation" class="container" width="100%" cellpadding="0" cellspacing="0">
            <tr>
              <td class="header">
                <h1 class="title">{{ issue.newsletter_name }}</h1>
                <p class="date">Issue date: {{ issue.run_date.isoformat() }}</p>
              </td>
            </tr>
            <tr>
              <td class="intro">{{ issue.intro }}</td>
            </tr>
            {% for story in issue.stories %}
            <tr>
              <td class="story">
                <h2>{{ loop.index }}. {{ story.headline }}</h2>
                <p class="meta">{{ story.date.isoformat() }}</p>
                <p class="summary">{{ story.summary }}</p>
                <p class="why"><strong>Why it matters:</strong> {{ story.why_it_matters }}</p>
                <p class="sources">
                  Sources:
                  {% for source in story.sources %}
                    <a href="{{ source.url }}">{{ source.name }}</a>{% if not loop.last %}; {% endif %}
                  {% endfor %}
                </p>
              </td>
            </tr>
            {% endfor %}
            <tr>
              <td class="footer">{{ issue.disclaimer }}</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
