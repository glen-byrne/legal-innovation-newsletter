<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ issue.newsletter_name }}</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background: #F5F1EA;
        color: #1E3B2E;
        font-family: Arial, Helvetica, sans-serif;
      }
      table { border-collapse: collapse; }
      img { border: 0; display: block; }
      a { color: #1E3B2E !important; text-decoration: underline; }
      .wrapper {
        width: 100%;
        background: #F5F1EA;
      }
      .container {
        width: 100%;
        max-width: 680px;
        margin: 0 auto;
        background: #FFFCF7;
      }
      .outer-pad {
        padding: 28px 14px;
      }
      .masthead {
        padding: 34px 30px 28px 30px;
        background: #1E3B2E;
        color: #F5F1EA;
        text-align: center;
      }
      .brand-icon-wrap {
        display: inline-block;
        margin: 0 auto 12px auto;
      }
      .brand-icon {
        width: 52px;
        height: auto;
        max-height: 72px;
      }
      .title-main {
        margin: 0;
        color: #F5F1EA;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 34px;
        line-height: 1.15;
        font-weight: normal;
        text-transform: uppercase;
      }
      .title-country {
        margin: 4px 0 0 0;
        color: #F5F1EA;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 22px;
        line-height: 1.15;
        font-weight: normal;
        text-transform: uppercase;
        letter-spacing: 0;
      }
      .tagline {
        margin: 16px 0 0 0;
        color: #DCCBB2;
        font-size: 14px;
        line-height: 1.5;
      }
      .subscribe-button {
        display: inline-block;
        margin-top: 14px;
        padding: 10px 16px;
        border: 1px solid #DCCBB2;
        border-radius: 999px;
        color: #F5F1EA !important;
        text-decoration: none;
        font-size: 13px;
        font-weight: bold;
      }
      .issue-meta {
        padding: 16px 30px;
        background: #DCCBB2;
        color: #1E3B2E;
        font-size: 13px;
        line-height: 1.45;
      }
      .intro {
        padding: 28px 30px;
        background: #FFFCF7;
        border-bottom: 1px solid #DCCBB2;
        color: #2A2A24;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 18px;
        line-height: 1.6;
      }
      .story {
        padding: 26px 30px;
        background: #FFFCF7;
        border-bottom: 1px solid #DCCBB2;
      }
      .story-number {
        width: 34px;
        height: 34px;
        border-radius: 17px;
        background: #1E3B2E;
        color: #F5F1EA;
        font-size: 14px;
        line-height: 34px;
        text-align: center;
        font-weight: bold;
      }
      .story h2 {
        margin: 0;
        color: #1E3B2E;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 23px;
        line-height: 1.25;
        font-weight: normal;
      }
      .meta {
        margin: 8px 0 0 0;
        color: #8B7966;
        font-size: 13px;
        line-height: 1.45;
      }
      .issue-disclaimer {
        margin: 8px 0 0 0;
        color: #2A2A24;
        font-size: 12px;
        line-height: 1.5;
      }
      .region-tags {
        margin: 10px 0 0 0;
      }
      .region-tag {
        display: inline-block;
        margin: 0 6px 6px 0;
        padding: 4px 8px;
        border: 1px solid #DCCBB2;
        border-radius: 999px;
        background: #F5F1EA;
        color: #5A3E2B;
        font-size: 12px;
        line-height: 1.2;
        font-weight: bold;
      }
      .summary {
        margin: 16px 0 0 0;
        color: #2A2A24;
        font-size: 15px;
        line-height: 1.62;
      }
      .why {
        margin: 16px 0 0 0;
        padding: 12px 14px;
        background: #F5F1EA;
        border-left: 3px solid #5A3E2B;
        color: #2A2A24;
        font-size: 15px;
        line-height: 1.55;
      }
      .why strong {
        color: #5A3E2B;
      }
      .sources {
        margin: 16px 0 0 0;
        color: #8B7966;
        font-size: 13px;
        line-height: 1.55;
      }
      .sources strong {
        color: #5A3E2B;
      }
      .empty-title {
        margin: 0 0 10px 0;
        color: #1E3B2E;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 22px;
        line-height: 1.3;
        font-weight: normal;
      }
      .footer {
        padding: 24px 30px 30px 30px;
        background: #1E3B2E;
        color: #DCCBB2;
        font-size: 12px;
        line-height: 1.55;
        text-align: center;
      }
      .feedback-button {
        display: inline-block;
        margin-top: 12px;
        padding: 10px 16px;
        border: 1px solid #DCCBB2;
        border-radius: 999px;
        color: #F5F1EA !important;
        text-decoration: none;
        font-size: 13px;
        font-weight: bold;
      }
      .unsubscribe-link {
        color: #DCCBB2 !important;
      }
      @media screen and (max-width: 520px) {
        .outer-pad { padding: 0 !important; }
        .masthead { padding: 28px 20px 24px 20px !important; }
        .issue-meta, .intro, .story, .footer { padding-left: 20px !important; padding-right: 20px !important; }
        .title-main { font-size: 29px !important; }
        .title-country { font-size: 18px !important; }
        .story h2 { font-size: 20px !important; }
        .intro { font-size: 16px !important; }
      }
    </style>
  </head>
  <body>
    <table role="presentation" class="wrapper" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td class="outer-pad" align="center">
          <table role="presentation" class="container" width="100%" cellpadding="0" cellspacing="0">
            <tr>
              <td class="masthead">
                <span class="brand-icon-wrap"><img class="brand-icon" src="{{ brand_icon_src }}" width="52" alt=""></span>
                <h1 class="title-main">The Legal Edge</h1>
                <h1 class="title-country">Ireland</h1>
                <p class="tagline">The latest on legal innovation, technology, AI and design for the Irish legal sector.</p>
                <a class="subscribe-button" href="{{ subscribe_url }}">Click here to subscribe</a>
              </td>
            </tr>
            <tr>
              <td class="issue-meta">
                <strong>Issue: {{ format_date(issue.run_date) }}</strong>
                <p class="issue-disclaimer">{{ issue.disclaimer }}</p>
              </td>
            </tr>
            {% if not issue.stories %}
            <tr>
              <td class="story">
                <h2 class="empty-title">No Qualified Stories</h2>
                <p class="summary">No stories met the source, date-window, relevance, and QA requirements for this run.</p>
              </td>
            </tr>
            {% endif %}
            {% for story in issue.stories %}
            <tr>
              <td class="story">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td width="46" valign="top">
                      <div class="story-number">{{ loop.index }}</div>
                    </td>
                    <td valign="top">
                      <h2>{{ story.headline }}</h2>
                      <p class="meta">{{ format_date(story.date) }}</p>
                      {% if story.region_tags %}
                      <p class="region-tags">
                        {% for region in story.region_tags %}
                        <span class="region-tag">{{ region }}</span>
                        {% endfor %}
                      </p>
                      {% endif %}
                    </td>
                  </tr>
                </table>
                <p class="summary">{{ story.summary }}</p>
                <p class="why"><strong>Impact:</strong> {{ story.why_it_matters }}</p>
                <p class="sources">
                  <strong>Sources:</strong>
                  {% for source in story.sources %}
                    <a href="{{ source.url }}">{{ source.name }}</a>{% if not loop.last %}; {% endif %}
                  {% endfor %}
                </p>
              </td>
            </tr>
            {% endfor %}
            <tr>
              <td class="footer">
                <a class="feedback-button" href="mailto:legal.innovation.news@gmail.com">What do you think? Provide feedback</a>
                <p><a class="unsubscribe-link" href="{{ unsubscribe_url }}">Unsubscribe</a></p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
